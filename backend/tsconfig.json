{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "lib": ["ESNext"],
    "types": ["node"]
  },
  "include": ["src/**/*", "api/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
